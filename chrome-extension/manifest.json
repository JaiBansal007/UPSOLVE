{
  "manifest_version": 3,
  "name": "CF Upsolve Companion",
  "version": "1.0",
  "description": "One-click add Codeforces problems to your Upsolve list.",
  "action": {
    "default_icon": "icons/icon_128.png",
    "default_title": "Add to CF-Upsolve"
  },
  "permissions": [
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon_128.png",
    "48": "icons/icon_128.png",
    "128": "icons/icon_128.png"
  }
}
